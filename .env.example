# ── Server ────────────────────────────────────────────────────
# Core server configuration: which port(s) to listen on and
# which network interface to bind to.
#   PORT       — HTTPS port (the primary entry point for the app)
#   HTTP_PORT  — plain HTTP port (redirects to HTTPS when TLS is configured)
#   HOST       — bind address; 0.0.0.0 = all interfaces
PORT=3001
HTTP_PORT=3000
HOST=0.0.0.0

# ── CORS ──────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated). Leave empty to disable
# CORS (same-origin only — the default when the server serves
# its own SPA). Set explicitly when the frontend runs on a
# different origin.
# Example: CORS_ORIGIN=https://ticketcraft.example.com,https://preview.example.com
CORS_ORIGIN=

# ── Rate Limiting ─────────────────────────────────────────────
# Maximum number of API requests allowed per 15-minute window
# from a single IP. Increase for heavy development/testing.
RATE_LIMIT_MAX=100

# ── TLS / HTTPS ──────────────────────────────────────────────
# Paths to the certificate and private key files for HTTPS.
# Run `npm run generate-certs` to create self-signed certs,
# or provide paths to your own CA-signed files.
# When both are set the server starts in HTTPS mode.
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Gemini AI (REQUIRED) ─────────────────────────────────────
# Google Gemini API key — powers all AI operations: scoring,
# improving, guiding questions, annotations, refinement chat,
# and repo-usage summaries.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default Gemini model used when a user hasn't chosen one.
# Users can override this per session from the header dropdown.
# Available: gemini-3.1-pro-preview | gemini-3.1-flash-lite-preview | gemini-3-flash-preview

GEMINI_DEFAULT_MODEL=gemini-3.1-pro-preview

# ── Jira (REQUIRED) ──────────────────────────────────────────
# Base URL of your Atlassian Jira Cloud instance.
# Users provide their own Jira email + API token on the login screen.
JIRA_BASE_URL=https://yourcompany.atlassian.net

# ── Admin ─────────────────────────────────────────────────────
# Comma-separated list of Jira email addresses that are allowed
# to access admin endpoints (settings, logs, Cursor config).
# Credentials are verified against Jira on admin routes.
ADMIN_EMAILS=you@example.com

# ── Session ──────────────────────────────────────────────────
# Inactivity timeout in milliseconds. After this period with no
# API calls the frontend shows a warning and eventually ends
# the session. Default: 1800000 (30 minutes).
SESSION_TIMEOUT_MS=1800000
